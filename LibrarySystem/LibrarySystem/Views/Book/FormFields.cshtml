@using LibrarySystem.Dtos
@model FormFields
<h1>Form Fields</h1>
<form asp-controller="Book" asp-action="FormFields" method="post">
    <div class="form-group">
        <label>Text Box</label>
        <input type="text" asp-for="TextValue" class="form-control"/>
    </div>
    <br/>
    <div class="form-group">
        <label>Select Books</label>
        <select class="form-control" asp-for="BookId" asp-items="Model.BookList">
            <option value="">Select A Book</option>
        </select>
    </div>
    <br />
    <div class="form-group">
        <label>Gender</label>
        <input type="radio" asp-for="Gender" value="Male" class="form-check-input"/><label class="form-check-label">Male</label> 
        <input type="radio" asp-for="Gender" value="Female" class="form-check-input" /> <label class="form-check-label">Female</label>
    </div>
    <br>
    <div class="form-group">

        @{
            for (int i = 0; i < Model.Hobbies.Count; i++)
            {
                <input type="hidden" asp-for="Hobbies[i].Name" />
                <input type="checkbox" asp-for="Hobbies[i].IsSelected" class="form-check-input" /> <label class="form-check-label">@Model.Hobbies[i].Name</label>
            }
        }
    </div>
    <div class="form-group">
        <input type="submit" class="btn btn-primary" value="Submit" />
    </div>


</form>