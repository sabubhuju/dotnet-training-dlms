@model LibrarySystem.Dtos.BookDetails
<h1>Add Book</h1>
<form asp-controller="Book" asp-action="AddBook" method="post">
    <div class="text-danger">@TempData["Message"]</div>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Name">Book Name</label>
        <input type="text" asp-for="Name" placeholder="Enter Book Name" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Author">Author Name</label>
        <input type="text" asp-for="Author" placeholder="Enter Author Name" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Publication">Publication</label>
        <input type="text" asp-for="Publication" placeholder="Enter Publication Name" class="form-control" />
    </div>
    <br>
    <div class="form-group">
        <input type="submit" value="Submit" class="btn btn-success" />
    </div>
    
</form>


@section Scripts {
@{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    
    }
}